; XInput caching shim DLL export definitions.
; Ordinals match the real Windows xinput1_3.dll for binary compatibility.
;
; Build: x86_64-w64-mingw32-gcc -shared -o assets/xinput1_3_cache.dll \
;        tools/xinput_cache.c tools/xinput_cache.def -municode -lkernel32
LIBRARY xinput1_3
EXPORTS
    XInputGetState               @2
    XInputSetState               @3
    XInputGetCapabilities        @4
    XInputEnable                 @5
    XInputGetBatteryInformation  @7
    XInputGetKeystroke           @8
